# ── Required ──────────────────────────────────────────────────────────────────

# Your Google Gemini API key (used to generate episode descriptions)
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# The full URL of the YouTube playlist to process
PLAYLIST_URL=https://www.youtube.com/playlist?list=PLxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────

# OpenAI API key — only needed if some episodes have no YouTube captions and
# you want to transcribe the audio via the Whisper API.
# If left blank, episodes without captions will be skipped.
OPENAI_API_KEY=sk-...
